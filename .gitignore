# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
# Ignore all platform build outputs EXCEPT build/web (Vercel needs that artifact)
# Note: git cannot negate a directory that's already fully ignored, so we enumerate
# the subdirs we want blocked rather than using a blanket /build/ exclusion.
/build/android/
/build/ios/
/build/linux/
/build/macos/
/build/windows/
/build/app/
/build/*.symbols
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
.vercel
